# Python
venv/
__pycache__/
*.pyc
*.pyo

# Downloaded data / trained models / generated charts —
# these are regenerated by running the pipeline, no need to commit them
data/*.csv
models/*.pkl
outputs/*.png

# Keep the folders themselves tracked in git even though contents are ignored
!data/.gitkeep
!models/.gitkeep
!outputs/.gitkeep

# OS junk
.DS_Store
Thumbs.db

# Editor junk
.vscode/
.idea/
